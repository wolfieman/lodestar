# Copy to .env and fill in. .env is gitignored — never commit real keys.

# OpenAI API key for the reference implementation (gpt-4o-mini).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# When true, the chatbot returns a deterministic mock instead of calling the API.
# Keep true for offline runs and unit tests; set false for real responses.
TEST_MODE=true
