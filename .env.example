# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- IgniteAI rebuild (default provider: Claude) ---
# Anthropic API key for live runs. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Provider + model overrides (defaults shown).
LODESTAR_PROVIDER=anthropic
# LODESTAR_MODEL=claude-sonnet-4-6

# --- v1 reproduction (lodestar) only ---
OPENAI_API_KEY=

# When true (default), chatbots return a deterministic offline mock — no API calls,
# no key needed. Set false for real model responses.
TEST_MODE=true
